# Local edge -> AWS cloud backend.
# The RDS database is PRIVATE (not reachable from the internet). The local edge
# devices talk to the cloud over authenticated HTTP through the ALB, so you only
# need the ALB URL + the ingest token below. Copy the values from the
# `bash aws/deploy.sh` output.
#
# PowerShell:  set each with  $env:NAME="value"
# bash:        set -a; source aws/.env.aws.example; set +a

# ---- main.py (serial reader) PUSHES readings to the cloud over HTTP ----------
CLOUD_URL=REPLACE_WITH_AlbUrl         # e.g. http://health-station-alb-xxxx.ap-southeast-1.elb.amazonaws.com
# ingest token the cloud requires on /api/ingest + /api/fall + /api/ai_frame.
# get it:  aws secretsmanager get-secret-value --region ap-southeast-1 \
#            --secret-id <IngestSecretArn> --query SecretString --output text
INGEST_TOKEN=REPLACE_WITH_INGEST_TOKEN
SIM=0
SERIAL_PORT=COM7

# ---- GPU YOLO detector reports falls / frames to the cloud dashboard ---------
# Use the ALB URL (not API Gateway) so the annotated MJPEG stream works.
DASHBOARD_URL=REPLACE_WITH_AlbUrl
CAMERA_SOURCE=http://<iphone-ip>:8081/video
